# ============================================
# NOLLYCREW ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env.local and fill in your values

# Database Configuration (required for production)
DATABASE_URL=postgresql://username:password@localhost:5432/nollycrew

# JWT Secret (required - generate a random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# OpenAI (required for AI features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Paystack (required for payments)
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

# Email Delivery (choose one)

# Option 1: SendGrid (recommended)
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Option 2: SMTP (Gmail, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Email sender address
EMAIL_FROM=NollyCrew <noreply@nollycrew.com>

# Application
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5000

# Optional: Redis (for job queues)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
