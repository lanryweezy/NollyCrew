{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/**, public/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/escrow",
      "schedule": "0 0 * * *"
    }
  ]
}
