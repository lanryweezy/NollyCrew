{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/**",
      "maxDuration": 30
    },
    "api/cron/escrow.ts": {
      "includeFiles": "dist/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/escrow",
      "schedule": "0 0 * * *"
    }
  ]
}
